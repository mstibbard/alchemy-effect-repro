{
	"name": "flow",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"alchemy": "2.0.0-beta.15",
			"effect": "4.0.0-beta.48"
		}
	},
	"scripts": {
		"deploy": "turbo run deploy",
		"dev": "turbo run dev",
		"fmt": "oxfmt",
		"lint": "oxlint",
		"precommit": "bun run fmt && bun run typecheck && bun run lint && bun run test",
		"prepare": "effect-tsgo patch",
		"purge:node_modules": "find . -name 'node_modules' -type d -prune -print -exec rm -rf '{}' \\;",
		"test": "turbo run test",
		"test:watch": "turbo run test -- --watch",
		"typecheck": "turbo run typecheck"
	},
	"devDependencies": {
		"@effect/platform-bun": "4.0.0-beta.48",
		"@effect/platform-node": "4.0.0-beta.48",
		"@effect/tsgo": "0.5.1",
		"@types/bun": "1.3.13",
		"@typescript/native-preview": "7.0.0-dev.20260424.2",
		"oxfmt": "0.46.0",
		"oxlint": "1.61.0",
		"turbo": "2.9.6"
	},
	"packageManager": "bun@1.3.13"
}
