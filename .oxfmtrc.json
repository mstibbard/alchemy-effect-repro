{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"endOfLine": "lf",
	"ignorePatterns": ["dist/**", "*.min.js"],
	"printWidth": 120,
	"semi": true,
	"singleQuote": false,
	"sortImports": true,
	"sortPackageJson": {
		"sortScripts": true
	},
	"sortTailwindcss": true,
	"tabWidth": 2,
	"trailingComma": "all",
	"useTabs": true
}
