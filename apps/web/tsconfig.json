{
	"extends": "../../tsconfig.base.json",
	"include": ["alchemy.run.ts", "src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
	"compilerOptions": {
		"rootDir": ".",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"jsx": "react-jsx",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"types": ["bun", "vite/client"]
	}
}
